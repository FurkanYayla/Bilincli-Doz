<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bilinçli Doz & Dijital Şifahane</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .serif-font { font-family: 'Lora', serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased overflow-x-hidden">

    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-2">
                    <div class="bg-teal-600 text-white p-2 rounded-xl shadow-md shadow-teal-600/20">
                        <i class="fa-solid fa-heart-pulse text-lg"></i>
                    </div>
                    <span class="font-extrabold text-xl tracking-tight bg-gradient-to-r from-teal-950 to-teal-700 bg-clip-text text-transparent">Bilinçli Doz</span>
                </div>
                <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
                    <a href="#vizyon" class="hover:text-teal-600 transition">Vizyonumuz</a>
                    <a href="#altin-sorular" class="hover:text-teal-600 transition">5 Altın Soru</a>
                    <a href="#qr-rehber" class="hover:text-teal-600 transition">QR Kod Sistemi</a>
                    <a href="#sifahane" class="hover:text-teal-600 transition">Dijital Şifahane</a>
                </div>
                <div>
                    <span class="hidden sm:inline-block text-xs font-semibold bg-teal-50 text-teal-700 px-3 py-1.5 rounded-full border border-teal-100">Sosyal Sorumluluk Hareketi</span>
                </div>
            </div>
        </div>
    </nav>

    <header id="vizyon" class="relative bg-gradient-to-br from-teal-950 via-teal-900 to-emerald-950 text-white py-24 px-4 overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:24px_24px]"></div>
        <div class="max-w-5xl mx-auto text-center relative z-10 space-y-8">
            <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase">
                <i class="fa-solid fa-leaf text-[10px]"></i> Akılcı İlaç & Bütünsel Sağlık Hareketi
            </div>
            <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight max-w-4xl mx-auto leading-[1.15]">
                Bilinçli Doz ve <br><span class="bg-gradient-to-r from-emerald-400 to-teal-300 bg-clip-text text-transparent serif-font italic font-normal">Dijital Şifahane</span>
            </h1>
            <p class="text-base sm:text-lg text-teal-100/80 max-w-2xl mx-auto leading-relaxed">
                Günümüzde artan bilinçsiz ilaç kullanımının yıkıcı etkilerine karşı farkındalık oluşturuyoruz. Modern tıbbın rasyonel ilkelerini, Türk-İslam medeniyetinin ruhu ve bedeni bütünleştiren kadim darüşşifa kültürüyle bir araya getiriyoruz.
            </p>
            <div class="pt-4 flex flex-wrap justify-center gap-4">
                <a href="#altin-sorular" class="bg-emerald-500 hover:bg-emerald-400 text-teal-950 font-bold px-8 py-3.5 rounded-xl shadow-lg shadow-emerald-500/20 transition transform hover:-translate-y-0.5 text-sm">
                    5 Altın Soru'yi Keşfet
                </a>
                <a href="#sifahane" class="bg-white/5 hover:bg-white/10 text-white border border-white/20 font-medium px-8 py-3.5 rounded-xl transition text-sm">
                    Müzik Terapisini Dinle
                </a>
            </div>
        </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-20">
        <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white p-8 rounded-2xl shadow-xl shadow-slate-200/50 border border-rose-50 flex flex-col justify-between group hover:border-rose-200 transition">
                <div>
                    <div class="bg-rose-50 text-rose-600 h-12 w-12 rounded-xl flex items-center justify-center mb-6 text-xl">
                        <i class="fa-solid fa-biohazard"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Antibiyotik Direnci</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">
                        Gereksiz ve yarım bırakılan antibiyotik kullanımı, bakterilerin direnç kazanmasına neden olarak en basit enfeksiyonları bile gelecekte ölümcül hale getiriyor.
                    </p>
                </div>
                <div class="mt-6 pt-4 border-t border-slate-50 text-xs font-semibold text-rose-600 bg-rose-50/50 py-2 px-3 rounded-lg w-fit">
                    Kritik Küresel Tehdit
                </div>
            </div>
            <div class="bg-white p-8 rounded-2xl shadow-xl shadow-slate-200/50 border border-amber-50 flex flex-col justify-between group hover:border-amber-200 transition">
                <div>
                    <div class="bg-amber-50 text-amber-600 h-12 w-12 rounded-xl flex items-center justify-center mb-6 text-xl">
                        <i class="fa-solid fa-capsules"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Organ Tahribatı</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">
                        En ufak bir fiziksel veya ruhsal gerilimde hemen kimyasal ağrı kesicilere sarılmak, karaciğer ve böbreklerimizde geri dönüşsüz hasarlar bırakıyor.
                    </p>
                </div>
                <div class="mt-6 pt-4 border-t border-slate-50 text-xs font-semibold text-amber-600 bg-amber-50/50 py-2 px-3 rounded-lg w-fit">
                    Psikosomatik Yükler
                </div>
            </div>
            <div class="bg-white p-8 rounded-2xl shadow-xl shadow-slate-200/50 border border-teal-50 flex flex-col justify-between group hover:border-teal-200 transition">
                <div>
                    <div class="bg-teal-50 text-teal-600 h-12 w-12 rounded-xl flex items-center justify-center mb-6 text-xl">
                        <i class="fa-solid fa-money-bill-trend-up"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Milli Ekonomik İsraf</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">
                        Evlerde bilinçsizce biriktirilen, kullanılmayan ve tarihi geçerek çöpe atılan atıl ilaçlar her yıl milyonlarca dolarlık milli servet kaybına yol açıyor.
                    </p>
                </div>
                <div class="mt-6 pt-4 border-t border-slate-50 text-xs font-semibold text-teal-600 bg-teal-50/50 py-2 px-3 rounded-lg w-fit">
                    Maddi & Ekolojik Kayıp
                </div>
            </div>
        </div>
    </section>

    <section id="altin-sorular" class="py-24 max-w-5xl mx-auto px-4">
        <div class="text-center space-y-4 mb-16">
            <span class="text-xs font-bold uppercase tracking-widest text-teal-600 bg-teal-50 px-3 py-1 rounded-md">Akılcı İlaç Danışmanlığı</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900">İlaç Alırken "5 Altın Soru"</h2>
            <p class="text-slate-500 max-w-xl mx-auto text-sm sm:text-base">
                Sağlığınızı korumak adına, doktorunuzdan veya eczacınızdan ilaçlarınızı teslim alırken bu 5 temel sorunun cevabını mutlaka öğrenin.
            </p>
        </div>

        <div class="space-y-4 max-w-3xl mx-auto">
            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden transition shadow-sm">
                <button onclick="toggleAccordion(1)" class="w-full flex items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 transition">
                    <span class="flex items-center gap-3 text-sm sm:text-base">
                        <span class="h-7 w-7 rounded-lg bg-teal-50 text-teal-700 flex items-center justify-center text-xs font-bold shrink-0">1</span>
                        İlacı nasıl hazırlayacağım?
                    </span>
                    <i id="icon-1" class="fa-solid fa-chevron-down text-xs text-slate-400 transition-transform duration-300"></i>
                </button>
                <div id="content-1" class="max-h-0 overflow-hidden transition-all duration-300 bg-slate-50/50">
                    <p class="p-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
                        Özellikle toz halindeki süspansiyon ilaçlar veya şurupların sulandırılma oranları, steril su kullanımı ve çalkalama süreleri hayati önem taşır. Yanlış hazırlanan ilaçlar etkinliğini kaybedebilir veya eksik doz alınmasına sebep olur.
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden transition shadow-sm">
                <button onclick="toggleAccordion(2)" class="w-full flex items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 transition">
                    <span class="flex items-center gap-3 text-sm sm:text-base">
                        <span class="h-7 w-7 rounded-lg bg-teal-50 text-teal-700 flex items-center justify-center text-xs font-bold shrink-0">2</span>
                        İlacı nasıl kullanacağım?
                    </span>
                    <i id="icon-2" class="fa-solid fa-chevron-down text-xs text-slate-400 transition-transform duration-300"></i>
                </button>
                <div id="content-2" class="max-h-0 overflow-hidden transition-all duration-300 bg-slate-50/50">
                    <p class="p-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
                        Aç karnına mı, tok karnına mı alınacak? Çiğnenerek mi yutulacak, doğrudan suyla mı? Bazı hapların bölünerek içilmesi koruyucu kaplamasını bozarak mideye zarar verebilir veya bağırsaktaki emilimi engelleyebilir. Doğru uygulama şifanın ilk şartıdır.
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden transition shadow-sm">
                <button onclick="toggleAccordion(3)" class="w-full flex items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 transition">
                    <span class="flex items-center gap-3 text-sm sm:text-base">
                        <span class="h-7 w-7 rounded-lg bg-teal-50 text-teal-700 flex items-center justify-center text-xs font-bold shrink-0">3</span>
                        İlacı günün hangi saatlerinde ve kaç kez kullanacağım?
                    </span>
                    <i id="icon-3" class="fa-solid fa-chevron-down text-xs text-slate-400 transition-transform duration-300"></i>
                </button>
                <div id="content-3" class="max-h-0 overflow-hidden transition-all duration-300 bg-slate-50/50">
                    <p class="p-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
                        "Günde 3 defa" ifadesi rastgele sabah-öğle-akşam demek değildir; kanda ilaç düzeyinin sabit kalabilmesi için tam 8 saatte bir (24 saat / 3) alınması gerekir. Saat düzenine milimetrik sadakat, bakterilerin veya hastalığın boşluk bulmasını engeller.
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden transition shadow-sm">
                <button onclick="toggleAccordion(4)" class="w-full flex items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 transition">
                    <span class="flex items-center gap-3 text-sm sm:text-base">
                        <span class="h-7 w-7 rounded-lg bg-teal-50 text-teal-700 flex items-center justify-center text-xs font-bold shrink-0">4</span>
                        İlaç tedavim kaç gün sürecek?
                    </span>
                    <i id="icon-4" class="fa-solid fa-chevron-down text-xs text-slate-400 transition-transform duration-300"></i>
                </button>
                <div id="content-4" class="max-h-0 overflow-hidden transition-all duration-300 bg-slate-50/50">
                    <p class="p-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
                        Kendinizi iyi hissettiğiniz an ilacı bırakmak en büyük hatalardan biridir. Özellikle antibiyotiklerde, vücutta kalan dirençli az sayıdaki mikroorganizma tedavinin yarıda kesilmesiyle çoğalarak hastalığın çok daha şiddetli nüksetmesine neden olur.
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden transition shadow-sm">
                <button onclick="toggleAccordion(5)" class="w-full flex items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 transition">
                    <span class="flex items-center gap-3 text-sm sm:text-base">
                        <span class="h-7 w-7 rounded-lg bg-teal-50 text-teal-700 flex items-center justify-center text-xs font-bold shrink-0">5</span>
                        İlacı kullanırken kaçınmam gereken yiyecek ve içecekler var mı?
                    </span>
                    <i id="icon-5" class="fa-solid fa-chevron-down text-xs text-slate-400 transition-transform duration-300"></i>
                </button>
                <div id="content-5" class="max-h-0 overflow-hidden transition-all duration-300 bg-slate-50/50">
                    <p class="p-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
                        Bazı besinler ilaçlarla etkileşime girer. Örneğin greyfurt suyu birçok ilacın karaciğerde yıkımını engelleyerek kanda aşırı birikmesine ve ciddi zehirlenmelere yol açabilir. Süt ve süt ürünleri ise bazı antibiyotiklerin emilimini tamamen durdurabilir.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="qr-rehber" class="bg-teal-900 text-white py-24 px-4">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <span class="bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 px-3 py-1 rounded-md text-xs font-bold tracking-wider uppercase">Teknoloji Entegrasyonu</span>
                <h2 class="text-3xl sm:text-4xl font-extrabold leading-tight">İlaç Kutularındaki QR Kodlar ve Saklama Isısı</h2>
                <p class="text-teal-100/80 leading-relaxed text-sm sm:text-base">
                    İlaç kutularının üzerinde yer alan karekodlar (İlaç Takip Sistemi - ITS), ilacın sadece sahte olup olmadığını denetlemez; aynı zamanda o ilacın dijital kimlik kartıdır. 
                </p>
                <div class="bg-teal-950/40 p-5 rounded-xl border border-teal-800 space-y-3">
                    <h4 class="font-bold text-emerald-400 flex items-center gap-2 text-sm sm:text-base">
                        <i class="fa-solid fa-snowflake"></i> Soğuk Zincir ve Saklama Dereceleri
                    </h4>
                    <p class="text-xs sm:text-sm text-teal-200/90 leading-relaxed">
                        Çoğu ilaç 15-25°C arasındaki oda sıcaklığında saklanırken, bazı biyolojik ürünler, insülinler ve aşılar 2-8°C buzdolabı ortamı (soğuk zincir) gerektirir. Uygun sıcaklıkta tutulmayan ilaçların kimyasal yapısı bozularak şifa yerine toksik maddelere dönüşebilir.
                    </p>
                </div>
            </div>

            <div class="flex justify-center">
                <div class="bg-white text-slate-900 p-8 rounded-3xl shadow-2xl max-w-sm w-full border-4 border-teal-950 relative group">
                    <div class="text-center space-y-4">
                        <div class="mx-auto bg-slate-100 p-6 rounded-2xl w-fit relative">
                            <i class="fa-solid fa-qrcode text-8xl text-teal-950"></i>
                            <div class="absolute inset-0 border-2 border-emerald-500 rounded-2xl animate-pulse pointer-events-none m-4"></div>
                        </div>
                        <h4 class="font-bold text-lg">Karekod Bilgi Sistemi</h4>
                        <p class="text-xs text-slate-500">Aşağıdaki butona tıklayarak bir ilaç kutusu üzerindeki QR kodun simülasyon çıktısını test edin.</p>
                        
                        <button onclick="simulateQrScan()" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 px-4 rounded-xl text-xs transition tracking-wide shadow-md">
                            <i class="fa-solid fa-camera mr-2"></i> KAREKODU SİMÜLE ET
                        </button>

                        <div id="qr-result" class="hidden mt-4 p-4 bg-emerald-50 rounded-xl border border-emerald-100 text-left space-y-2">
                            <div class="flex items-center justify-between text-[11px] font-bold text-emerald-800 uppercase tracking-wider">
                                <span>İlaç Durumu: Bakanlık Onaylı</span>
                                <i class="fa-solid fa-circle-check text-emerald-600"></i>
                            </div>
                            <div class="text-xs font-bold text-slate-900">Parasetamol 500 mg Antienflamatuar</div>
                            <div class="text-[11px] text-slate-600 space-y-1 border-t border-emerald-200/50 pt-2 mt-1">
                                <div><strong>Maksimum Isı:</strong> 25°C (Oda Sıcaklığı)</div>
                                <div><strong>Nem Koşulu:</strong> Kuru, Kutusunda ve Işıksız Ortam</div>
                                <div class="text-rose-600 font-semibold mt-1"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Buzdolabına koymayınız, dondurmayınız.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="sifahane" class="py-24 max-w-6xl mx-auto px-4">
        <div class="bg-gradient-to-br from-amber-50/80 via-orange-50/40 to-stone-100 rounded-3xl p-8 md:p-16 border border-amber-200/50 grid md:grid-cols-5 gap-12 items-center relative overflow-hidden">
            <div class="absolute right-0 bottom-0 translate-x-10 translate-y-10 opacity-[0.02] text-amber-950 pointer-events-none">
                <i class="fa-solid fa-music text-[300px]"></i>
            </div>
            
            <div class="md:col-span-3 space-y-6">
                <span class="bg-amber-100 text-amber-800 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Kültürel Miras & Ruhsal Arınma</span>
                <h2 class="text-3xl sm:text-4xl font-bold text-amber-950 serif-font">Kadim Darüşşifalar ve Müzik Terapisi</h2>
                <p class="text-slate-700 leading-relaxed text-sm sm:text-base">
                    Projemiz, her psikolojik gerginlikte, uykusuzlukta veya strese bağlı baş ağrısında hemen ağır kimyasallara sığınmak yerine insanı ruh ve beden bütünlüğüyle ele alır. 
                </p>
                <p class="text-slate-600 leading-relaxed text-sm">
                    Ecdadımız, Selçuklu ve Osmanlı darüşşifalarında (Edirne Sultan II. Bayezid Darüşşifası gibi) hastaları su sesi ve özel müzik makamlarıyla tedavi ediyordu. Büyük İslam hekim ve düşünürleri İbn Sina ve Farabi, hangi makamın günün hangi saatinde zihne ve fıtrata iyi geldiğini bilimsel olarak tasnif etmişlerdi.
                </p>
                
                <div class="grid grid-cols-2 gap-4 pt-2">
                    <div class="bg-white/80 p-3 rounded-xl border border-amber-200/40">
                        <div class="font-bold text-amber-900 text-xs sm:text-sm">Rast Makamı</div>
                        <div class="text-[11px] text-slate-500">İnsana neşe, sefa ve iç huzuru verir; kemik ve kas sistemine olumlu etkileri bilinir.</div>
                    </div>
                    <div class="bg-white/80 p-3 rounded-xl border border-amber-200/40">
                        <div class="font-bold text-amber-900 text-xs sm:text-sm">Nihavend Makamı</div>
                        <div class="text-[11px] text-slate-500">Kan dolaşımını sakinleştirir, tansiyonu dengeler, zihni derin düşüncelerden arındırır.</div>
                    </div>
                </div>
            </div>

            <div class="md:col-span-2 bg-white p-6 rounded-2xl shadow-xl border border-amber-200/30 space-y-4">
                <div class="text-center font-bold text-sm text-amber-950 uppercase tracking-wider pb-2 border-b border-slate-100">
                    Şifahane Ses Oynatıcı
                </div>
                <div class="flex items-center gap-4 bg-slate-50 p-3 rounded-xl">
                    <button id="play-btn" onclick="toggleMusic()" class="h-10 w-10 bg-amber-600 hover:bg-amber-700 text-white rounded-full flex items-center justify-center transition shrink-0 shadow-md">
                        <i id="play-icon" class="fa-solid fa-play ml-0.5"></i>
                    </button>
                    <div class="w-full">
                        <div class="text-xs font-bold text-slate-900" id="track-name">Rast Makamı - Kadim Terapi Melodisi</div>
                        <div class="text-[10px] text-slate-500">Geleneksel Ney & Ud Sentezi (Simüle Oynatım)</div>
                        <div class="w-full bg-slate-200 h-1 rounded-full mt-2 overflow-hidden">
                            <div id="progress-bar" class="bg-amber-600 h-full w-0 transition-all duration-300"></div>
                        </div>
                    </div>
                </div>
                <p class="text-[11px] text-slate-500 italic text-center leading-normal">
                    *Müzik terapisi, zihinsel dinginlik sağlayarak stres kaynaklı psikosomatik ilaç ihtiyacını (anksiyete, uykusuzluk hapları vb.) azaltmayı hedefler.
                </p>
            </div>
        </div>
    </section>

    <footer class="bg-slate-900 text-slate-400 py-12 px-4 border-t border-slate-800 text-center text-xs">
        <div class="max-w-4xl mx-auto space-y-4">
            <p class="font-bold text-slate-300 text-sm">Bilinçli Doz - Akılcı İlaç Kullanımı Sosyal Sorumluluk Projesi</p>
            <p class="max-w-xl mx-auto text-slate-500 leading-relaxed">
                Bu web sitesi, toplum sağlığını tehdit eden gereksiz ilaç tüketimine karşı toplumsal bilinç oluşturmak amacıyla hazırlanmış bir mezuniyet ödevi çalışmasıdır.
            </p>
            <div class="pt-4 text-slate-600 border-t border-slate-800">
                &copy; 2026 Bilinçli Doz ve Dijital Şifahane Hareketi. Tüm Hakları Saklıdır.
            </div>
        </div>
    </footer>

    <script>
        // 1. Akordeon Menü (5 Altın Soru Açma/Kapatma)
        let activeId = null;
        function toggleAccordion(id) {
            const content = document.getElementById(`content-${id}`);
            const icon = document.getElementById(`icon-${id}`);
            
            if (activeId === id) {
                content.style.maxHeight = '0px';
                icon.style.transform = 'rotate(0deg)';
                activeId = null;
                return;
            }
            if (activeId !== null) {
                document.getElementById(`content-${activeId}`).style.maxHeight = '0px';
                document.getElementById(`icon-${activeId}`).style.transform = 'rotate(0deg)';
            }
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            activeId = id;
        }

        // 2. QR Kod Tarama Simülatör Tetikleyici
        function simulateQrScan() {
            const resultBox = document.getElementById('qr-result');
            resultBox.classList.remove('hidden');
            resultBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // 3. Mini Müzik Çalar Animasyon Simülasyonu
        let isPlaying = false;
        let progressInterval;
        function toggleMusic() {
            const playIcon = document.getElementById('play-icon');
            const progressBar = document.getElementById('progress-bar');
            const trackName = document.getElementById('track-name');
            
            isPlaying = !isPlaying;
            
            if (isPlaying) {
                playIcon.className = 'fa-solid fa-pause';
                trackName.classList.add('text-amber-600');
                let width = 0;
                progressInterval = setInterval(() => {
                    width += 1;
                    if (width > 100) width = 0; 
                    progressBar.style.width = width + '%';
                }, 150);
            } else {
                playIcon.className = 'fa-solid fa-play';
                trackName.classList.remove('text-amber-600');
                clearInterval(progressInterval);
            }
        }
    </script>
</body>
</html>
